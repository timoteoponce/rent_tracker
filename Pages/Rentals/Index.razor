@page "/rentals"
@attribute [Authorize]
@inject ApplicationDbContext Context

<PageTitle>Rentals - Rent Tracker</PageTitle>

<h1>Rentals</h1>

<div class="mb-2">
    <a href="/rentals/add" class="btn btn-primary">New Rental</a>
</div>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else if (!_rentals.Any())
{
    <div class="alert alert-info">No rentals found.</div>
}
else
{
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Property</th>
                    <th>Tenant</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Rent</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rental in _rentals)
                {
                    <tr>
                        <td>
                            @if (rental.Property != null)
                            {
                                <a href="/properties/@rental.Property.Id">Property #@rental.Property.Id</a>
                            }
                            else
                            {
                                <span>Unknown</span>
                            }
                        </td>
                        <td>@(rental.Tenant?.FullName ?? "Unknown")</td>
                        <td>@rental.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@(rental.EndDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                        <td>@rental.MonthlyRent.ToString("N2") BOB</td>
                        <td>
                            @switch (rental.Status)
                            {
                                case RentalStatus.Active:
                                    <span class="badge badge-success">Active</span>
                                    break;
                                case RentalStatus.Closed:
                                    <span class="badge badge-info">Closed</span>
                                    break;
                                case RentalStatus.Terminated:
                                    <span class="badge badge-warning">Terminated</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a href="/rentals/@rental.Id" class="btn btn-sm btn-outline">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading = true;
    private List<Rental> _rentals = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadRentals();
        _loading = false;
    }

    private async Task LoadRentals()
    {
        _rentals = await Context.Rentals
            .Include(r => r.Property)
            .Include(r => r.Tenant)
            .OrderByDescending(r => r.StartDate)
            .ToListAsync();
    }
}
