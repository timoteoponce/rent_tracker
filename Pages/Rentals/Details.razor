@page "/rentals/{Id:int}"
@attribute [Authorize]
@inject ApplicationDbContext Context
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Rental Details - Rent Tracker</PageTitle>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else if (_rental == null)
{
    <div class="alert alert-danger">Rental not found.</div>
}
else
{
    <div class="d-flex justify-between align-center mb-2">
        <h1>Rental Details</h1>
        <div class="d-flex gap-1">
            <a href="/rentals" class="btn btn-outline">Back</a>
        </div>
    </div>

    <div class="card">
        <div class="d-flex justify-between align-center mb-2">
            <h2>Information</h2>
            @switch (_rental.Status)
            {
                case RentalStatus.Active:
                    <span class="badge badge-success">Active</span>
                    break;
                case RentalStatus.Closed:
                    <span class="badge badge-info">Closed</span>
                    break;
                case RentalStatus.Terminated:
                    <span class="badge badge-warning">Terminated</span>
                    break;
            }
        </div>

        <div class="form-group">
            <label>Property</label>
            <p>
                @if (_rental.Property != null)
                {
                    <a href="/properties/@_rental.Property.Id">Property #@_rental.Property.Id</a>
                    <br />
                    <small class="text-muted">
                        @_rental.Property.SurfaceSquareMeters m², @_rental.Property.NumberOfRooms rooms
                    </small>
                }
                else
                {
                    <span>Unknown</span>
                }
            </p>
        </div>

        <div class="form-group">
            <label>Tenant</label>
            <p>@(_rental.Tenant?.FullName ?? "Unknown")</p>
        </div>

        <div class="form-group">
            <label>Start Date</label>
            <p>@_rental.StartDate.ToString("MMM dd, yyyy")</p>
        </div>

        @if (_rental.EndDate.HasValue)
        {
            <div class="form-group">
                <label>End Date</label>
                <p>@_rental.EndDate.Value.ToString("MMM dd, yyyy")</p>
            </div>
        }

        <div class="form-group">
            <label>Monthly Rent</label>
            <p>@_rental.MonthlyRent.ToString("N2") BOB</p>
        </div>

        <div class="form-group">
            <label>Warranty Amount</label>
            <p>@_rental.WarrantyAmount.ToString("N2") BOB</p>
        </div>

        @if (!string.IsNullOrEmpty(_rental.TerminationReason))
        {
            <div class="form-group">
                <label>Termination Reason</label>
                <p>@_rental.TerminationReason</p>
            </div>
        }
    </div>

    @if (_rental.Status == RentalStatus.Active)
    {
        <div class="card">
            <h2>Actions</h2>
            <div class="d-flex gap-1">
                <button class="btn btn-secondary" @onclick="() => _showCloseModal = true">Close Rental</button>
                <button class="btn btn-danger" @onclick="() => _showTerminateModal = true">Terminate Rental</button>
            </div>
        </div>
    }

    <div class="card">
        <div class="d-flex justify-between align-center mb-2">
            <h2>Payments</h2>
            @if (_rental.Status == RentalStatus.Active)
            {
                <a href="/payments/add?rentalId=@_rental.Id" class="btn btn-success">Add Payment</a>
            }
        </div>

        @if (_payments.Any())
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Period</th>
                            <th>Amount</th>
                            <th>Version</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in _payments.Where(p => p.PreviousPaymentId == null))
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td>@payment.PeriodStart.ToString("MMM dd") - @payment.PeriodEnd.ToString("MMM dd, yyyy")</td>
                                <td>@payment.Amount.ToString("N2") BOB</td>
                                <td>@payment.Version</td>
                                <td>
                                    <a href="/payments/edit/@payment.Id" class="btn btn-sm btn-outline">Update</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No payments recorded</p>
        }
    </div>

    @if (_showCloseModal)
    {
        <div class="modal-overlay" @onclick="() => _showCloseModal = false">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Close Rental</h3>
                    <button class="btn btn-sm btn-outline" @onclick="() => _showCloseModal = false">X</button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to close this rental?</p>
                    <div class="form-group">
                        <label for="endDate">End Date</label>
                        <InputDate id="endDate" @bind-Value="_endDate" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showCloseModal = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="CloseRental" disabled="@_processing">Close Rental</button>
                </div>
            </div>
        </div>
    }

    @if (_showTerminateModal)
    {
        <div class="modal-overlay" @onclick="() => _showTerminateModal = false">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Terminate Rental</h3>
                    <button class="btn btn-sm btn-outline" @onclick="() => _showTerminateModal = false">X</button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning">
                        This will forcibly end the rental. Please provide a reason.
                    </div>
                    <div class="form-group">
                        <label for="endDate">End Date</label>
                        <InputDate id="endDate" @bind-Value="_endDate" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label for="reason">Termination Reason</label>
                        <textarea id="reason" @bind="_terminationReason" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showTerminateModal = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="TerminateRental" disabled="@_processing">Terminate</button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Rental? _rental;
    private List<RentalPayment> _payments = [];
    private bool _loading = true;
    private bool _showCloseModal;
    private bool _showTerminateModal;
    private bool _processing;
    private DateTime _endDate = DateTime.Today;
    private string _terminationReason = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadRental();
        _loading = false;
    }

    private async Task LoadRental()
    {
        _rental = await Context.Rentals
            .Include(r => r.Property)
            .Include(r => r.Tenant)
            .Include(r => r.Payments)
            .FirstOrDefaultAsync(r => r.Id == Id);

        if (_rental != null)
        {
            _payments = _rental.Payments.OrderByDescending(p => p.PaymentDate).ToList();
        }
    }

    private async Task CloseRental()
    {
        if (_rental == null || _processing) return;
        _processing = true;

        try
        {
            _rental.Status = RentalStatus.Closed;
            _rental.EndDate = _endDate;
            await Context.SaveChangesAsync();

            _showCloseModal = false;
            await LoadRental();
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task TerminateRental()
    {
        if (_rental == null || _processing || string.IsNullOrWhiteSpace(_terminationReason)) return;
        _processing = true;

        try
        {
            _rental.Status = RentalStatus.Terminated;
            _rental.EndDate = _endDate;
            _rental.TerminationReason = _terminationReason;
            await Context.SaveChangesAsync();

            _showTerminateModal = false;
            await LoadRental();
        }
        finally
        {
            _processing = false;
        }
    }
}
