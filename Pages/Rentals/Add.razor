@page "/rentals/add"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject ApplicationDbContext Context
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>New Rental - Rent Tracker</PageTitle>

<h1>New Rental</h1>

<EditForm Model="_rental" OnValidSubmit="HandleSubmit" class="card">
    <DataAnnotationsValidator />
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="form-group">
        <label for="property">Property</label>
        <InputSelect id="property" @bind-Value="_rental.PropertyId" class="form-control" required>
            <option value="">Select a property...</option>
            @foreach (var property in _availableProperties)
            {
                <option value="@property.Id">Property #@property.Id - @property.SurfaceSquareMeters m², @property.NumberOfRooms rooms (@property.CurrentPrice.ToString("N2") BOB)</option>
            }
        </InputSelect>
        <ValidationMessage For="() => _rental.PropertyId" />
    </div>

    <div class="form-group">
        <label for="tenant">Tenant</label>
        <InputSelect id="tenant" @bind-Value="_rental.TenantId" class="form-control" required>
            <option value="">Select a tenant...</option>
            @foreach (var user in _tenants)
            {
                <option value="@user.Id">@user.FullName</option>
            }
        </InputSelect>
        <ValidationMessage For="() => _rental.TenantId" />
    </div>

    <div class="form-group">
        <label for="startDate">Start Date</label>
        <InputDate id="startDate" @bind-Value="_rental.StartDate" class="form-control" required />
        <ValidationMessage For="() => _rental.StartDate" />
    </div>

    <div class="form-group">
        <label for="monthlyRent">Monthly Rent (BOB)</label>
        <InputNumber id="monthlyRent" @bind-Value="_rental.MonthlyRent" class="form-control" min="0" step="0.01" required />
        <ValidationMessage For="() => _rental.MonthlyRent" />
    </div>

    <div class="form-group">
        <label for="warranty">Warranty Amount (BOB)</label>
        <InputNumber id="warranty" @bind-Value="_rental.WarrantyAmount" class="form-control" min="0" step="0.01" required />
        <ValidationMessage For="() => _rental.WarrantyAmount" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary" disabled="@_saving">
            @if (_saving)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Create Rental</span>
            }
        </button>
        <a href="/rentals" class="btn btn-outline">Cancel</a>
    </div>
</EditForm>

@code {
    [SupplyParameterFromQuery]
    public int? PropertyId { get; set; }

    private RentalInput _rental = new()
    {
        StartDate = DateTime.Today
    };
    private List<Property> _availableProperties = [];
    private List<ApplicationUser> _tenants = [];
    private string? _errorMessage;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        // Load available properties (enabled and not currently rented)
        var allProperties = await Context.Properties
            .Where(p => p.IsEnabled)
            .Include(p => p.Rentals)
            .ToListAsync();

        _availableProperties = allProperties
            .Where(p => p.CurrentRental == null)
            .OrderBy(p => p.Id)
            .ToList();

        _tenants = (await UserManager.GetUsersInRoleAsync("Tenant")).OrderBy(t => t.FullName).ToList();

        // Pre-select property if provided
        if (PropertyId.HasValue && _availableProperties.Any(p => p.Id == PropertyId.Value))
        {
            _rental.PropertyId = PropertyId.Value;
            var property = _availableProperties.First(p => p.Id == PropertyId.Value);
            _rental.MonthlyRent = property.CurrentPrice;
            _rental.WarrantyAmount = property.CurrentWarranty;
        }
    }

    private async Task HandleSubmit()
    {
        if (_saving) return;
        _saving = true;
        _errorMessage = null;

        try
        {
            // Verify property is still available
            var property = await Context.Properties
                .Include(p => p.Rentals)
                .FirstOrDefaultAsync(p => p.Id == _rental.PropertyId);

            if (property == null)
            {
                _errorMessage = "Property not found.";
                return;
            }

            if (property.CurrentRental != null)
            {
                _errorMessage = "Property is already rented.";
                return;
            }

            var rental = new Rental
            {
                PropertyId = _rental.PropertyId,
                TenantId = _rental.TenantId,
                StartDate = _rental.StartDate,
                MonthlyRent = _rental.MonthlyRent,
                WarrantyAmount = _rental.WarrantyAmount,
                Status = RentalStatus.Active
            };

            Context.Rentals.Add(rental);
            await Context.SaveChangesAsync();

            Navigation.NavigateTo("/rentals");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error creating rental: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class RentalInput
    {
        [Required(ErrorMessage = "Please select a property")]
        public int PropertyId { get; set; }

        [Required(ErrorMessage = "Please select a tenant")]
        public string TenantId { get; set; } = "";

        [Required]
        public DateTime StartDate { get; set; }

        [Required]
        [Range(0, double.MaxValue)]
        public decimal MonthlyRent { get; set; }

        [Required]
        [Range(0, double.MaxValue)]
        public decimal WarrantyAmount { get; set; }
    }
}
