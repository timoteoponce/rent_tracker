@page "/"
@attribute [Authorize]
@inject ApplicationDbContext Context

<PageTitle>Dashboard - Rent Tracker</PageTitle>

<h1>Dashboard</h1>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@_stats.TotalProperties</div>
            <div class="stat-label">Total Properties</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_stats.ActiveRentals</div>
            <div class="stat-label">Active Rentals</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_stats.OccupancyRate%</div>
            <div class="stat-label">Occupancy Rate</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_stats.MonthlyIncome.ToString("N2") BOB</div>
            <div class="stat-label">Monthly Income</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Monthly Income (Last 6 Months)</h2>
        </div>
        <div class="chart-container">
            <canvas id="incomeChart"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Occupancy Overview</h2>
        </div>
        <div class="chart-container">
            <canvas id="occupancyChart"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Recent Activity</h2>
        </div>
        @if (_recentActivity.Any())
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Property</th>
                            <th>Activity</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var activity in _recentActivity)
                        {
                            <tr>
                                <td>@activity.Date.ToString("MMM dd, yyyy")</td>
                                <td>@activity.PropertyName</td>
                                <td>@activity.Description</td>
                                <td>@(activity.Amount > 0 ? $"{activity.Amount:N2} BOB" : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No recent activity</p>
        }
    </div>
}

<script>
    window.renderCharts = function (incomeData, occupancyData) {
        // Income Chart
        const incomeCtx = document.getElementById('incomeChart')?.getContext('2d');
        if (incomeCtx) {
            new Chart(incomeCtx, {
                type: 'bar',
                data: {
                    labels: incomeData.labels,
                    datasets: [{
                        label: 'Income (BOB)',
                        data: incomeData.values,
                        backgroundColor: '#2563eb',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value + ' BOB';
                                }
                            }
                        }
                    }
                }
            });
        }

        // Occupancy Chart
        const occupancyCtx = document.getElementById('occupancyChart')?.getContext('2d');
        if (occupancyCtx) {
            new Chart(occupancyCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Rented', 'Available'],
                    datasets: [{
                        data: [occupancyData.rented, occupancyData.available],
                        backgroundColor: ['#16a34a', '#dc2626'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }
    };
</script>

@code {
    private bool _loading = true;
    private DashboardStats _stats = new();
    private List<RecentActivity> _recentActivity = [];
    private IncomeChartData _incomeData = new();
    private OccupancyChartData _occupancyData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100); // Ensure DOM is ready
            await JSRuntime.InvokeVoidAsync("renderCharts", _incomeData, _occupancyData);
        }
    }

    private async Task LoadDashboardData()
    {
        // Stats
        var totalProperties = await Context.Properties.CountAsync();
        var enabledProperties = await Context.Properties.CountAsync(p => p.IsEnabled);
        var activeRentals = await Context.Rentals.CountAsync(r => r.Status == RentalStatus.Active);
        
        _stats.TotalProperties = totalProperties;
        _stats.ActiveRentals = activeRentals;
        _stats.OccupancyRate = enabledProperties > 0 ? (int)((double)activeRentals / enabledProperties * 100) : 0;
        
        var monthlyIncome = (await Context.Rentals
            .Where(r => r.Status == RentalStatus.Active)
            .ToListAsync())
            .Sum(r => r.MonthlyRent);
        _stats.MonthlyIncome = monthlyIncome;

        // Occupancy data
        _occupancyData.Rented = activeRentals;
        _occupancyData.Available = enabledProperties - activeRentals;

        // Income chart data (last 6 months)
        var now = DateTime.UtcNow;
        var labels = new List<string>();
        var values = new List<decimal>();
        
        for (int i = 5; i >= 0; i--)
        {
            var month = now.AddMonths(-i);
            var startOfMonth = new DateTime(month.Year, month.Month, 1);
            var endOfMonth = startOfMonth.AddMonths(1).AddDays(-1);
            
            var income = (await Context.RentalPayments
                .Where(p => p.PaymentDate >= startOfMonth && p.PaymentDate <= endOfMonth)
                .ToListAsync())
                .Sum(p => p.Amount);
            
            labels.Add(month.ToString("MMM yyyy"));
            values.Add(income);
        }
        
        _incomeData.Labels = labels;
        _incomeData.Values = values;

        // Recent activity
        _recentActivity = await Context.RentalPayments
            .Include(p => p.Rental)
            .ThenInclude(r => r!.Property)
            .OrderByDescending(p => p.PaymentDate)
            .Take(5)
            .Select(p => new RecentActivity
            {
                Date = p.PaymentDate,
                PropertyName = p.Rental!.Property != null ? $"Property #{p.Rental.Property.Id}" : "Unknown",
                Description = $"Payment received (Version {p.Version})",
                Amount = p.Amount
            })
            .ToListAsync();
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private class DashboardStats
    {
        public int TotalProperties { get; set; }
        public int ActiveRentals { get; set; }
        public int OccupancyRate { get; set; }
        public decimal MonthlyIncome { get; set; }
    }

    private class RecentActivity
    {
        public DateTime Date { get; set; }
        public required string PropertyName { get; set; }
        public required string Description { get; set; }
        public decimal Amount { get; set; }
    }

    private class IncomeChartData
    {
        public List<string> Labels { get; set; } = [];
        public List<decimal> Values { get; set; } = [];
    }

    private class OccupancyChartData
    {
        public int Rented { get; set; }
        public int Available { get; set; }
    }
}
