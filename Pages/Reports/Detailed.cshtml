@page
@model RentTracker.Web.Pages.Reports.DetailedModel
@{
    ViewData["Title"] = "Detailed Reports";
}

<div class="page-header">
    <h2>Detailed Breakdown</h2>
    <a asp-page="./Index" class="btn btn-secondary">Back to Summary</a>
</div>

<div class="page-content">
    <div class="filters mb-4">
        <form method="get" class="form-row">
            <div class="form-group">
                <label asp-for="StartDate"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="EndDate"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="PropertyId"></label>
                <select asp-for="PropertyId" asp-items="Model.Properties" class="form-control">
                    <option value="">All Properties</option>
                </select>
            </div>
            <div class="form-group">
                <label>&nbsp;</label>
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-page="./Detailed" class="btn btn-secondary">Reset</a>
            </div>
        </form>
    </div>

    <div class="stats-grid mb-4">
        <div class="stat-card">
            <span class="stat-label">Total Revenue (Period)</span>
            <span class="stat-value">Bs. @Model.TotalRevenue.ToString("N2")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Total Payments</span>
            <span class="stat-value">@Model.TotalPayments</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Average Payment</span>
            <span class="stat-value">Bs. @Model.AveragePayment.ToString("N2")</span>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Payment Breakdown by Property</h3>
        </div>
        @if (Model.PropertyBreakdown.Any())
        {
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Property</th>
                            <th>Total Payments</th>
                            <th>Total Revenue</th>
                            <th>Average</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PropertyBreakdown)
                        {
                            <tr>
                                <td>@item.PropertyName</td>
                                <td>@item.PaymentCount</td>
                                <td>Bs. @item.TotalAmount.ToString("N2")</td>
                                <td>Bs. @item.AverageAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No payment data for the selected period.</p>
        }
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Monthly Revenue Table</h3>
        </div>
        @if (Model.MonthlyBreakdown.Any())
        {
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th>Number of Payments</th>
                            <th>Total Revenue</th>
                            <th>Pending</th>
                            <th>Received</th>
                            <th>Late</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.MonthlyBreakdown)
                        {
                            <tr>
                                <td>@item.Month.ToString("MMM yyyy")</td>
                                <td>@item.PaymentCount</td>
                                <td>Bs. @item.TotalRevenue.ToString("N2")</td>
                                <td>@item.PendingCount</td>
                                <td>@item.ReceivedCount</td>
                                <td>@item.LateCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No payment data for the selected period.</p>
        }
    </div>
</div>
