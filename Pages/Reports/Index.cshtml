@page
@model RentTracker.Web.Pages.Reports.IndexModel
@using RentTracker.Web.Models
@{
    ViewData["Title"] = "Reports";
}

<partial name="_PageHeader" model='new PageHeaderModel { Title = "Reports Dashboard", ActionUrl = "./Detailed", ActionText = "Detailed Breakdown" }' />

<div class="page-content">
    <div class="stats-grid">
        <a asp-page="/Properties/Index" class="stat-card" aria-label="View all properties">
            <span class="stat-label">Total Properties</span>
            <span class="stat-value">@Model.TotalProperties</span>
        </a>
        <a asp-page="/Leases/Index" class="stat-card" aria-label="View active leases">
            <span class="stat-label">Occupied</span>
            <span class="stat-value">@Model.OccupiedProperties</span>
        </a>
        <a asp-page="/Properties/Index" class="stat-card" aria-label="View available properties">
            <span class="stat-label">Available</span>
            <span class="stat-value">@Model.AvailableProperties</span>
        </a>
        <a asp-page="/Payments/Index" class="stat-card" aria-label="View payments catalogue">
            <span class="stat-label">Total Revenue (This Month)</span>
            <span class="stat-value">Bs. @Model.ThisMonthRevenue.ToString("N0")</span>
        </a>
    </div>

    <div class="form-row">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Monthly Revenue (@Model.CurrentYear)</h3>
            </div>
            <div class="chart-container">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Payment Status Distribution</h3>
            </div>
            <div class="chart-container">
                <canvas id="paymentStatusChart"></canvas>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Property Status Overview</h3>
        </div>
        <div class="chart-container" style="height: 250px;">
            <canvas id="propertyStatusChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        // Dark mode color helper for charts
        function getChartColors() {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            return {
                primary: isDark ? 'rgba(96, 165, 250, 0.8)' : 'rgba(37, 99, 235, 0.8)',
                primaryBorder: isDark ? 'rgba(96, 165, 250, 1)' : 'rgba(37, 99, 235, 1)',
                success: isDark ? 'rgba(74, 222, 128, 0.8)' : 'rgba(22, 163, 74, 0.8)',
                warning: isDark ? 'rgba(251, 191, 36, 0.8)' : 'rgba(245, 158, 11, 0.8)',
                danger: isDark ? 'rgba(248, 113, 113, 0.8)' : 'rgba(220, 38, 38, 0.8)',
                gray: isDark ? 'rgba(156, 163, 175, 0.8)' : 'rgba(107, 114, 128, 0.8)',
                text: isDark ? '#9ca3af' : '#6b7280',
                grid: isDark ? '#374151' : '#e5e7eb'
            };
        }

        var colors = getChartColors();

        // Set global defaults so axes and legends follow the theme
        Chart.defaults.color = colors.text;
        Chart.defaults.borderColor = colors.grid;

        // Monthly Revenue Chart
        var revenueCtx = document.getElementById('revenueChart').getContext('2d');
        var revenueChart = new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MonthLabels)),
                datasets: [{
                    label: 'Revenue (BOB)',
                    data: @Html.Raw(Json.Serialize(Model.MonthlyRevenue)),
                    backgroundColor: colors.primary,
                    borderColor: colors.primaryBorder,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'Bs. ' + value.toLocaleString();
                            }
                        }
                    }
                }
            }
        });

        // Payment Status Chart
        var statusCtx = document.getElementById('paymentStatusChart').getContext('2d');
        var statusChart = new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.PaymentStatusLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.PaymentStatusCounts)),
                    backgroundColor: [
                        colors.warning,  // Pending
                        colors.success,  // Received
                        colors.primary,  // Partial
                        colors.danger    // Late
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });

        // Property Status Chart
        var propertyCtx = document.getElementById('propertyStatusChart').getContext('2d');
        var propertyChart = new Chart(propertyCtx, {
            type: 'pie',
            data: {
                labels: ['Occupied', 'Available', 'Disabled'],
                datasets: [{
                    data: [@Model.OccupiedProperties, @Model.AvailableProperties, @Model.DisabledProperties],
                    backgroundColor: [
                        colors.success, // Occupied
                        colors.primary, // Available
                        colors.gray     // Disabled
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });
    </script>
}
