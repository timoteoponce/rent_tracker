@page "/reports"
@attribute [Authorize]
@inject ApplicationDbContext Context

<PageTitle>Reports - Rent Tracker</PageTitle>

<h1>Reports</h1>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Property Summary</h2>
    </div>
    
    @if (_loading)
    {
        <div class="d-flex align-center gap-1">
            <div class="spinner"></div>
            <span>Loading...</span>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@_summary.TotalProperties</div>
                <div class="stat-label">Total Properties</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.EnabledProperties</div>
                <div class="stat-label">Enabled</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.RentedProperties</div>
                <div class="stat-label">Rented</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.AvailableProperties</div>
                <div class="stat-label">Available</div>
            </div>
        </div>

        <h3>Occupancy Rate</h3>
        <div class="chart-container">
            <canvas id="occupancyChart"></canvas>
        </div>
    }
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Payment Summary</h2>
    </div>

    @if (!_loading)
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@_summary.TotalPayments</div>
                <div class="stat-label">Total Payments</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.TotalRevenue.ToString("N0")</div>
                <div class="stat-label">Total Revenue (BOB)</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.ThisMonthRevenue.ToString("N0")</div>
                <div class="stat-label">This Month (BOB)</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.CurrentMonthlyIncome.ToString("N0")</div>
                <div class="stat-label">Current Monthly Income (BOB)</div>
            </div>
        </div>

        <h3>Monthly Income (Last 12 Months)</h3>
        <div class="chart-container">
            <canvas id="incomeChart"></canvas>
        </div>
    }
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Rental Activity</h2>
    </div>

    @if (!_loading)
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@_summary.ActiveRentals</div>
                <div class="stat-label">Active Rentals</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.TotalRentalsThisYear</div>
                <div class="stat-label">New This Year</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.ClosedRentals</div>
                <div class="stat-label">Closed</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_summary.TerminatedRentals</div>
                <div class="stat-label">Terminated</div>
            </div>
        </div>
    }
</div>

<script>
    window.renderReports = function (occupancyData, incomeData) {
        // Occupancy Chart
        const occupancyCtx = document.getElementById('occupancyChart')?.getContext('2d');
        if (occupancyCtx) {
            new Chart(occupancyCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Rented', 'Available'],
                    datasets: [{
                        data: [occupancyData.rented, occupancyData.available],
                        backgroundColor: ['#16a34a', '#dc2626'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }

        // Income Chart
        const incomeCtx = document.getElementById('incomeChart')?.getContext('2d');
        if (incomeCtx) {
            new Chart(incomeCtx, {
                type: 'line',
                data: {
                    labels: incomeData.labels,
                    datasets: [{
                        label: 'Income (BOB)',
                        data: incomeData.values,
                        backgroundColor: 'rgba(37, 99, 235, 0.1)',
                        borderColor: '#2563eb',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value + ' BOB';
                                }
                            }
                        }
                    }
                }
            });
        }
    };
</script>

@code {
    private bool _loading = true;
    private ReportSummary _summary = new();
    private OccupancyChartData _occupancyData = new();
    private IncomeChartData _incomeData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("renderReports", _occupancyData, _incomeData);
        }
    }

    private async Task LoadReports()
    {
        var now = DateTime.UtcNow;
        var startOfYear = new DateTime(now.Year, 1, 1);
        var startOfMonth = new DateTime(now.Year, now.Month, 1);

        _summary.TotalProperties = await Context.Properties.CountAsync();
        _summary.EnabledProperties = await Context.Properties.CountAsync(p => p.IsEnabled);
        _summary.RentedProperties = await Context.Rentals
            .CountAsync(r => r.Status == RentalStatus.Active);
        _summary.AvailableProperties = _summary.EnabledProperties - _summary.RentedProperties;

        _occupancyData.Rented = _summary.RentedProperties;
        _occupancyData.Available = _summary.AvailableProperties;

        _summary.TotalPayments = await Context.RentalPayments.CountAsync();
        _summary.TotalRevenue = (await Context.RentalPayments.ToListAsync()).Sum(p => p.Amount);
        _summary.ThisMonthRevenue = (await Context.RentalPayments
            .Where(p => p.PaymentDate >= startOfMonth)
            .ToListAsync()).Sum(p => p.Amount);
        _summary.CurrentMonthlyIncome = (await Context.Rentals
            .Where(r => r.Status == RentalStatus.Active)
            .ToListAsync()).Sum(r => r.MonthlyRent);

        var labels = new List<string>();
        var values = new List<decimal>();
        
        for (int i = 11; i >= 0; i--)
        {
            var month = now.AddMonths(-i);
            var monthStart = new DateTime(month.Year, month.Month, 1);
            var monthEnd = monthStart.AddMonths(1).AddDays(-1);
            
            var income = (await Context.RentalPayments
                .Where(p => p.PaymentDate >= monthStart && p.PaymentDate <= monthEnd)
                .ToListAsync()).Sum(p => p.Amount);
            
            labels.Add(month.ToString("MMM yyyy"));
            values.Add(income);
        }
        
        _incomeData.Labels = labels;
        _incomeData.Values = values;

        _summary.ActiveRentals = await Context.Rentals.CountAsync(r => r.Status == RentalStatus.Active);
        _summary.TotalRentalsThisYear = await Context.Rentals
            .CountAsync(r => r.StartDate >= startOfYear);
        _summary.ClosedRentals = await Context.Rentals.CountAsync(r => r.Status == RentalStatus.Closed);
        _summary.TerminatedRentals = await Context.Rentals.CountAsync(r => r.Status == RentalStatus.Terminated);
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private class ReportSummary
    {
        public int TotalProperties { get; set; }
        public int EnabledProperties { get; set; }
        public int RentedProperties { get; set; }
        public int AvailableProperties { get; set; }
        public int TotalPayments { get; set; }
        public decimal TotalRevenue { get; set; }
        public decimal ThisMonthRevenue { get; set; }
        public decimal CurrentMonthlyIncome { get; set; }
        public int ActiveRentals { get; set; }
        public int TotalRentalsThisYear { get; set; }
        public int ClosedRentals { get; set; }
        public int TerminatedRentals { get; set; }
    }

    private class OccupancyChartData
    {
        public int Rented { get; set; }
        public int Available { get; set; }
    }

    private class IncomeChartData
    {
        public List<string> Labels { get; set; } = [];
        public List<decimal> Values { get; set; } = [];
    }
}
