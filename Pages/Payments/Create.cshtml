@page
@model RentTracker.Web.Pages.Payments.CreateModel
@{
    ViewData["Title"] = "Add Payment";
}

<div class="page-header">
    <h2>Add Payment</h2>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="page-content">
    @if (!string.IsNullOrEmpty(Model.WarningMessage))
    {
        <div class="alert alert-warning">
            @Model.WarningMessage
        </div>
    }

    <form method="post" class="form-horizontal">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="form-group">
            <label asp-for="Payment.LeaseId"></label>
            <select asp-for="Payment.LeaseId" asp-items="Model.ActiveLeases" class="form-control">
                <option value="">-- Select Lease --</option>
            </select>
            <span asp-validation-for="Payment.LeaseId" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Payment.ForPeriod"></label>
                <input asp-for="Payment.ForPeriod" type="month" class="form-control" />
                <span asp-validation-for="Payment.ForPeriod" class="text-danger"></span>
                <small class="text-muted">Select the month/year this payment covers</small>
            </div>

            <div class="form-group">
                <label asp-for="Payment.PaymentDate"></label>
                <input asp-for="Payment.PaymentDate" type="date" class="form-control" />
                <span asp-validation-for="Payment.PaymentDate" class="text-danger"></span>
                <small class="text-muted">Date payment was received (defaults to today)</small>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Payment.Amount"></label>
                <input asp-for="Payment.Amount" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Payment.Amount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Payment.Currency"></label>
                <select asp-for="Payment.Currency" class="form-control">
                    <option value="BOB">BOB (Bolivianos)</option>
                    <option value="USD">USD (US Dollars)</option>
                </select>
                <span asp-validation-for="Payment.Currency" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Payment.Status"></label>
            <select asp-for="Payment.Status" class="form-control">
                <option value="Pending">Pending</option>
                <option value="Received">Received</option>
                <option value="Partial">Partial</option>
                <option value="Late">Late</option>
            </select>
            <span asp-validation-for="Payment.Status" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Payment.Notes"></label>
            <textarea asp-for="Payment.Notes" class="form-control" rows="2" placeholder="Optional notes about this payment"></textarea>
            <span asp-validation-for="Payment.Notes" class="text-danger"></span>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Add Payment</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Payment_LeaseId').addEventListener('change', function() {
            var leaseId = this.value;
            var amountInput = document.getElementById('Payment_Amount');
            
            if (leaseId) {
                // Fetch lease details to get the agreed price
                fetch('?handler=LeaseDetails&leaseId=' + leaseId)
                    .then(response => response.json())
                    .then(data => {
                        amountInput.value = data.agreedPrice.toFixed(2);
                    });
            } else {
                amountInput.value = '';
            }
        });
    </script>
}
