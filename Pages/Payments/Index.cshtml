@page
@model RentTracker.Web.Pages.Payments.IndexModel
@using RentTracker.Web.Models
@{
    ViewData["Title"] = "Payments";
}

<div class="page-header">
    <h2>Payments</h2>
    @if (User.IsInRole("Administrator") || User.IsInRole("Owner"))
    {
        <a asp-page="./Create" class="btn btn-primary">Add Payment</a>
    }
</div>

<div class="page-content">
    <div class="filters mb-3">
        <form method="get" class="form-inline">
            <label>Status:</label>
            <select asp-for="StatusFilter" class="form-control" onchange="this.form.submit()">
                <option value="">All</option>
                <option value="Pending">Pending</option>
                <option value="Received">Received</option>
                <option value="Partial">Partial</option>
                <option value="Late">Late</option>
            </select>
        </form>
    </div>

    @if (Model.Payments.Any())
    {
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Tenant</th>
                        <th>Period</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td>@payment.Lease.Property.Name</td>
                            <td>@(payment.Lease.PropertyUnit?.Name ?? "Whole Property")</td>
                            <td>@payment.Lease.Tenant.FullName</td>
                            <td>@payment.ForPeriod.ToString("MMM yyyy")</td>
                            <td>Bs. @payment.Amount.ToString("N2") @payment.Currency</td>
                            <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <partial name="_StatusBadge" model='new StatusBadgeModel { Status = payment.Status, Type = "Payment" }' />
                            </td>
                            <td>
                                @if (User.IsInRole("Administrator") || User.IsInRole("Owner"))
                                {
                                    <a asp-page="./Edit" asp-route-id="@payment.Id" class="btn btn-sm btn-secondary">Update</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model='new EmptyStateModel { Message = "No payments found." }' />
    }
</div>
