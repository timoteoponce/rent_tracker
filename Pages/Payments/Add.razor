@page "/payments/add"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject ApplicationDbContext Context
@inject NavigationManager Navigation

<PageTitle>Add Payment - Rent Tracker</PageTitle>

<h1>Add Payment</h1>

<EditForm Model="_payment" OnValidSubmit="HandleSubmit" class="card">
    <DataAnnotationsValidator />
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="form-group">
        <label for="rental">Rental</label>
        <InputSelect id="rental" @bind-Value="_payment.RentalId" class="form-control" required>
            <option value="">Select a rental...</option>
            @foreach (var rental in _activeRentals)
            {
                <option value="@rental.Id">
                    @rental.Property?.SurfaceSquareMeters m² - @(rental.Tenant?.FullName ?? "Unknown") 
                    (@rental.MonthlyRent.ToString("N2") BOB/month)
                </option>
            }
        </InputSelect>
        <ValidationMessage For="() => _payment.RentalId" />
    </div>

    <div class="form-group">
        <label for="amount">Amount (BOB)</label>
        <InputNumber id="amount" @bind-Value="_payment.Amount" class="form-control" min="0" step="0.01" required />
        <ValidationMessage For="() => _payment.Amount" />
    </div>

    <div class="form-group">
        <label for="paymentDate">Payment Date</label>
        <InputDate id="paymentDate" @bind-Value="_payment.PaymentDate" class="form-control" required />
        <ValidationMessage For="() => _payment.PaymentDate" />
    </div>

    <div class="form-group">
        <label for="periodStart">Period Start</label>
        <InputDate id="periodStart" @bind-Value="_payment.PeriodStart" class="form-control" required />
        <ValidationMessage For="() => _payment.PeriodStart" />
    </div>

    <div class="form-group">
        <label for="periodEnd">Period End</label>
        <InputDate id="periodEnd" @bind-Value="_payment.PeriodEnd" class="form-control" required />
        <ValidationMessage For="() => _payment.PeriodEnd" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary" disabled="@_saving">
            @if (_saving)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Record Payment</span>
            }
        </button>
        <a href="/payments" class="btn btn-outline">Cancel</a>
    </div>
</EditForm>

@code {
    [SupplyParameterFromQuery]
    public int? RentalId { get; set; }

    private PaymentInput _payment = new()
    {
        PaymentDate = DateTime.Today,
        PeriodStart = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
        PeriodEnd = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1).AddDays(-1)
    };
    private List<Rental> _activeRentals = [];
    private string? _errorMessage;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _activeRentals = await Context.Rentals
            .Where(r => r.Status == RentalStatus.Active)
            .Include(r => r.Property)
            .Include(r => r.Tenant)
            .OrderBy(r => r.Property!.Id)
            .ToListAsync();

        // Pre-select rental if provided
        if (RentalId.HasValue && _activeRentals.Any(r => r.Id == RentalId.Value))
        {
            _payment.RentalId = RentalId.Value;
            var rental = _activeRentals.First(r => r.Id == RentalId.Value);
            _payment.Amount = rental.MonthlyRent;
        }
    }

    private async Task HandleSubmit()
    {
        if (_saving) return;
        _saving = true;
        _errorMessage = null;

        try
        {
            var payment = new RentalPayment
            {
                RentalId = _payment.RentalId,
                Amount = _payment.Amount,
                PaymentDate = _payment.PaymentDate,
                PeriodStart = _payment.PeriodStart,
                PeriodEnd = _payment.PeriodEnd,
                Version = 1
            };

            Context.RentalPayments.Add(payment);
            await Context.SaveChangesAsync();

            Navigation.NavigateTo("/payments");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error recording payment: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class PaymentInput
    {
        [Required(ErrorMessage = "Please select a rental")]
        public int RentalId { get; set; }

        [Required]
        [Range(0, double.MaxValue)]
        public decimal Amount { get; set; }

        [Required]
        public DateTime PaymentDate { get; set; }

        [Required]
        public DateTime PeriodStart { get; set; }

        [Required]
        public DateTime PeriodEnd { get; set; }
    }
}
