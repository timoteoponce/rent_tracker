@page "/payments/edit/{Id:int}"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject ApplicationDbContext Context
@inject NavigationManager Navigation

<PageTitle>Update Payment - Rent Tracker</PageTitle>

<h1>Update Payment</h1>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else if (_originalPayment == null)
{
    <div class="alert alert-danger">Payment not found.</div>
}
else
{
    <div class="alert alert-info">
        This will create a new version of the payment. The original payment will be kept for audit purposes.
    </div>

    <div class="card mb-2">
        <h3>Original Payment (Version @_originalPayment.Version)</h3>
        <div class="form-group">
            <label>Amount</label>
            <p>@_originalPayment.Amount.ToString("N2") BOB</p>
        </div>
        <div class="form-group">
            <label>Date</label>
            <p>@_originalPayment.PaymentDate.ToString("MMM dd, yyyy")</p>
        </div>
        <div class="form-group">
            <label>Period</label>
            <p>@_originalPayment.PeriodStart.ToString("MMM dd") - @_originalPayment.PeriodEnd.ToString("MMM dd, yyyy")</p>
        </div>
    </div>

    <EditForm Model="_payment" OnValidSubmit="HandleSubmit" class="card">
        <DataAnnotationsValidator />
        
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <h3>New Version</h3>

        <div class="form-group">
            <label for="amount">Amount (BOB)</label>
            <InputNumber id="amount" @bind-Value="_payment.Amount" class="form-control" min="0" step="0.01" required />
            <ValidationMessage For="() => _payment.Amount" />
        </div>

        <div class="form-group">
            <label for="paymentDate">Payment Date</label>
            <InputDate id="paymentDate" @bind-Value="_payment.PaymentDate" class="form-control" required />
            <ValidationMessage For="() => _payment.PaymentDate" />
        </div>

        <div class="form-group">
            <label for="periodStart">Period Start</label>
            <InputDate id="periodStart" @bind-Value="_payment.PeriodStart" class="form-control" required />
            <ValidationMessage For="() => _payment.PeriodStart" />
        </div>

        <div class="form-group">
            <label for="periodEnd">Period End</label>
            <InputDate id="periodEnd" @bind-Value="_payment.PeriodEnd" class="form-control" required />
            <ValidationMessage For="() => _payment.PeriodEnd" />
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @if (_saving)
                {
                    <span>Saving...</span>
                }
                else
                {
                    <span>Create New Version</span>
                }
            </button>
            <a href="/payments" class="btn btn-outline">Cancel</a>
        </div>
    </EditForm>

    @if (_paymentHistory.Any())
    {
        <div class="card mt-2">
            <h3>Payment History</h3>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>Date</th>
                            <th>Period</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var history in _paymentHistory.OrderByDescending(h => h.Version))
                        {
                            <tr>
                                <td>@history.Version</td>
                                <td>@history.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td>@history.PeriodStart.ToString("MMM dd") - @history.PeriodEnd.ToString("MMM dd, yyyy")</td>
                                <td>@history.Amount.ToString("N2") BOB</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private RentalPayment? _originalPayment;
    private PaymentInput _payment = new();
    private List<RentalPayment> _paymentHistory = [];
    private string? _errorMessage;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        await LoadPayment();
        _loading = false;
    }

    private async Task LoadPayment()
    {
        _originalPayment = await Context.RentalPayments
            .FirstOrDefaultAsync(p => p.Id == Id && p.PreviousPaymentId == null);

        if (_originalPayment == null) return;

        // Load all versions of this payment
        _paymentHistory = (await Context.RentalPayments.ToListAsync())
            .Where(p => p.Id == Id || p.PreviousPaymentId == Id || 
                        (p.PreviousPayment != null && p.PreviousPayment.PreviousPaymentId == Id))
            .ToList();

        // Set defaults from original
        _payment = new PaymentInput
        {
            Amount = _originalPayment.Amount,
            PaymentDate = _originalPayment.PaymentDate,
            PeriodStart = _originalPayment.PeriodStart,
            PeriodEnd = _originalPayment.PeriodEnd
        };
    }

    private async Task HandleSubmit()
    {
        if (_saving || _originalPayment == null) return;
        _saving = true;
        _errorMessage = null;

        try
        {
            // Create new payment version
            var newPayment = new RentalPayment
            {
                RentalId = _originalPayment.RentalId,
                Amount = _payment.Amount,
                PaymentDate = _payment.PaymentDate,
                PeriodStart = _payment.PeriodStart,
                PeriodEnd = _payment.PeriodEnd,
                Version = _originalPayment.Version + 1,
                PreviousPaymentId = _originalPayment.Id
            };

            Context.RentalPayments.Add(newPayment);
            await Context.SaveChangesAsync();

            // Update the original payment to point to the new one
            // Actually, we keep the chain by having PreviousPaymentId
            // The UI will show the latest version by checking which payments have no newer versions

            Navigation.NavigateTo("/payments");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error updating payment: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class PaymentInput
    {
        [Required]
        [Range(0, double.MaxValue)]
        public decimal Amount { get; set; }

        [Required]
        public DateTime PaymentDate { get; set; }

        [Required]
        public DateTime PeriodStart { get; set; }

        [Required]
        public DateTime PeriodEnd { get; set; }
    }
}
