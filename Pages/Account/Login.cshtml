@page
@model RentTracker.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutAuth";
}

<div class="login-container">
    <h1>RentTracker</h1>
    
    <form method="post" class="login-form">
        @if (Model.MustChangePassword)
        {
            <div class="alert alert-warning">
                You must change your password before continuing.
            </div>
        }
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        
        <div class="form-group">
            <label asp-for="Input.LoginIdentifier"></label>
            <input asp-for="Input.LoginIdentifier" class="form-control" autocomplete="username" autofocus />
            <span asp-validation-for="Input.LoginIdentifier" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label class="checkbox">
                <input asp-for="Input.RememberMe" type="checkbox" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
        </div>
        
        <button type="submit" class="btn btn-primary btn-block">Login</button>
    </form>
    
    <div class="login-footer">
        <p>Default login: admin / admin</p>
        <p>You will be required to change the password on first login.</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
