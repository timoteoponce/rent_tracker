@page
@model RentTracker.Web.Pages.Properties.IndexModel
@using RentTracker.Web.Models
@{
    ViewData["Title"] = "Properties";
}

<partial name="_PageHeader" model='new PageHeaderModel { Title = "Properties", ActionUrl = "./Create", ActionText = "Add Property" }' />

<div class="page-content">
    @if (Model.Properties.Any())
    {
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Visibility</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model.Properties)
                    {
                        <tr>
                            <td>@property.Name</td>
                            <td>
                                @if (!string.IsNullOrEmpty(property.Location))
                                {
                                    <a href="@property.Location" target="_blank" rel="noopener noreferrer">View Map</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>Bs. @property.CurrentPrice.ToString("N2")</td>
                            <td>
                                @if (property.IsEnabled)
                                {
                                    <span class="badge badge-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Disabled</span>
                                }
                            </td>
                            <td>
                                @if (property.IsPrivate)
                                {
                                    <span class="badge badge-warning">Private</span>
                                }
                                else
                                {
                                    <span class="badge badge-info">Public</span>
                                }
                            </td>
                            <td>
                                <a asp-page="./Details" asp-route-id="@property.Id" class="btn btn-sm btn-secondary">View</a>
                                <a asp-page="./Edit" asp-route-id="@property.Id" class="btn btn-sm btn-secondary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model='new EmptyStateModel { Message = "No properties found.", ActionUrl = "./Create", ActionText = "Add your first property" }' />
    }
</div>
