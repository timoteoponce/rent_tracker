@page "/properties/edit/{Id:int}"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject ApplicationDbContext Context
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Edit Property - Rent Tracker</PageTitle>

<h1>Edit Property</h1>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else if (_property == null)
{
    <div class="alert alert-danger">Property not found.</div>
}
else
{
    <EditForm Model="_input" OnValidSubmit="HandleSubmit" class="card">
        <DataAnnotationsValidator />
        
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <div class="alert alert-info">
            <strong>Location:</strong> @_property.LocationLatitude.ToString("0.0000"), @_property.LocationLongitude.ToString("0.0000") (Cannot be changed)
        </div>

        <div class="form-group">
            <label for="surface">Surface (m²)</label>
            <InputNumber id="surface" @bind-Value="_input.SurfaceSquareMeters" class="form-control" min="1" required />
            <ValidationMessage For="() => _input.SurfaceSquareMeters" />
        </div>

        <div class="form-group">
            <label for="rooms">Number of Rooms</label>
            <InputNumber id="rooms" @bind-Value="_input.NumberOfRooms" class="form-control" min="1" required />
            <ValidationMessage For="() => _input.NumberOfRooms" />
        </div>

        <h3>Facilities</h3>
        <div class="facilities-grid">
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasBathroom" />
                <span>Bathroom</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasKitchen" />
                <span>Kitchen</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasGarage" />
                <span>Garage</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasHotWater" />
                <span>Hot Water</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasAC" />
                <span>Air Conditioning</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasBackyard" />
                <span>Backyard</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasSecurity" />
                <span>Security</span>
            </label>
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.HasDoorbell" />
                <span>Doorbell</span>
            </label>
        </div>

        <h3>Financial</h3>
        <div class="form-group">
            <label for="price">Monthly Price (BOB)</label>
            <InputNumber id="price" @bind-Value="_input.CurrentPrice" class="form-control" min="0" step="0.01" required />
            <ValidationMessage For="() => _input.CurrentPrice" />
        </div>

        <div class="form-group">
            <label for="warranty">Warranty Amount (BOB)</label>
            <InputNumber id="warranty" @bind-Value="_input.CurrentWarranty" class="form-control" min="0" step="0.01" required />
            <ValidationMessage For="() => _input.CurrentWarranty" />
        </div>

        <h3>Status</h3>
        <div class="form-group">
            <label class="checkbox-group">
                <InputCheckbox @bind-Value="_input.IsEnabled" />
                <span>Property Enabled</span>
            </label>
        </div>

        <h3>Owners</h3>
        <div class="form-group">
            @if (_users.Any())
            {
                <div class="facilities-grid">
                    @foreach (var user in _users)
                    {
                        <label class="checkbox-group">
                            <input type="checkbox" 
                                   checked="@_selectedOwnerIds.Contains(user.Id)"
                                   @onchange="(e) => ToggleOwner(user.Id, (bool)(e.Value ?? false))" />
                            <span>@user.FullName</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No users available</p>
            }
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @if (_saving)
                {
                    <span>Saving...</span>
                }
                else
                {
                    <span>Update Property</span>
                }
            </button>
            <a href="/properties" class="btn btn-outline">Cancel</a>
        </div>
    </EditForm>

    @if (_priceHistory.Any())
    {
        <div class="card mt-2">
            <h3>Price History</h3>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Price</th>
                            <th>Warranty</th>
                            <th>Changed By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var history in _priceHistory)
                        {
                            <tr>
                                <td>@history.EffectiveFrom.ToString("MMM dd, yyyy")</td>
                                <td>@history.Price.ToString("N2") BOB</td>
                                <td>@history.Warranty.ToString("N2") BOB</td>
                                <td>@(history.ChangedByUser?.FullName ?? "Unknown")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Property? _property;
    private PropertyInput _input = new();
    private List<ApplicationUser> _users = [];
    private List<string> _selectedOwnerIds = [];
    private List<PropertyPriceHistory> _priceHistory = [];
    private string? _errorMessage;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        await LoadProperty();
        _loading = false;
    }

    private async Task LoadProperty()
    {
        _property = await Context.Properties
            .Include(p => p.Owners)
            .FirstOrDefaultAsync(p => p.Id == Id);

        if (_property == null) return;

        _input = new PropertyInput
        {
            SurfaceSquareMeters = _property.SurfaceSquareMeters,
            NumberOfRooms = _property.NumberOfRooms,
            HasBathroom = _property.HasBathroom,
            HasKitchen = _property.HasKitchen,
            HasGarage = _property.HasGarage,
            HasHotWater = _property.HasHotWater,
            HasAC = _property.HasAC,
            HasBackyard = _property.HasBackyard,
            HasSecurity = _property.HasSecurity,
            HasDoorbell = _property.HasDoorbell,
            CurrentPrice = _property.CurrentPrice,
            CurrentWarranty = _property.CurrentWarranty,
            IsEnabled = _property.IsEnabled
        };

        _selectedOwnerIds = _property.Owners.Select(o => o.OwnerId).ToList();

        _users = (await UserManager.GetUsersInRoleAsync("Owner")).OrderBy(u => u.FullName).ToList();

        _priceHistory = await Context.PropertyPriceHistory
            .Include(h => h.ChangedByUser)
            .Where(h => h.PropertyId == Id)
            .OrderByDescending(h => h.EffectiveFrom)
            .ToListAsync();
    }

    private void ToggleOwner(string userId, bool selected)
    {
        if (selected)
        {
            if (!_selectedOwnerIds.Contains(userId))
            {
                _selectedOwnerIds.Add(userId);
            }
        }
        else
        {
            _selectedOwnerIds.Remove(userId);
        }
    }

    private async Task HandleSubmit()
    {
        if (_saving || _property == null) return;
        _saving = true;
        _errorMessage = null;

        try
        {
            // Check if price/warranty changed
            var priceChanged = _property.CurrentPrice != _input.CurrentPrice || 
                              _property.CurrentWarranty != _input.CurrentWarranty;

            // Update property
            _property.SurfaceSquareMeters = _input.SurfaceSquareMeters;
            _property.NumberOfRooms = _input.NumberOfRooms;
            _property.HasBathroom = _input.HasBathroom;
            _property.HasKitchen = _input.HasKitchen;
            _property.HasGarage = _input.HasGarage;
            _property.HasHotWater = _input.HasHotWater;
            _property.HasAC = _input.HasAC;
            _property.HasBackyard = _input.HasBackyard;
            _property.HasSecurity = _input.HasSecurity;
            _property.HasDoorbell = _input.HasDoorbell;
            _property.IsEnabled = _input.IsEnabled;

            if (priceChanged)
            {
                // Create price history entry before updating
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var currentUser = await UserManager.GetUserAsync(authState.User);
                Context.PropertyPriceHistory.Add(new PropertyPriceHistory
                {
                    PropertyId = _property.Id,
                    Price = _input.CurrentPrice,
                    Warranty = _input.CurrentWarranty,
                    EffectiveFrom = DateTime.UtcNow,
                    ChangedByUserId = currentUser?.Id ?? "unknown"
                });

                _property.CurrentPrice = _input.CurrentPrice;
                _property.CurrentWarranty = _input.CurrentWarranty;
            }

            // Update owners
            var existingOwners = _property.Owners.ToList();
            var ownersToRemove = existingOwners.Where(o => !_selectedOwnerIds.Contains(o.OwnerId)).ToList();
            var ownersToAdd = _selectedOwnerIds.Where(id => !existingOwners.Any(o => o.OwnerId == id)).ToList();

            foreach (var owner in ownersToRemove)
            {
                Context.PropertyOwners.Remove(owner);
            }

            foreach (var ownerId in ownersToAdd)
            {
                Context.PropertyOwners.Add(new PropertyOwner
                {
                    PropertyId = _property.Id,
                    OwnerId = ownerId,
                    Since = DateTime.UtcNow
                });
            }

            await Context.SaveChangesAsync();

            Navigation.NavigateTo("/properties");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error updating property: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class PropertyInput
    {
        [Required]
        [Range(1, int.MaxValue)]
        public int SurfaceSquareMeters { get; set; }

        [Required]
        [Range(1, int.MaxValue)]
        public int NumberOfRooms { get; set; }

        public bool HasBathroom { get; set; }
        public bool HasKitchen { get; set; }
        public bool HasGarage { get; set; }
        public bool HasHotWater { get; set; }
        public bool HasAC { get; set; }
        public bool HasBackyard { get; set; }
        public bool HasSecurity { get; set; }
        public bool HasDoorbell { get; set; }

        [Required]
        [Range(0, double.MaxValue)]
        public decimal CurrentPrice { get; set; }

        [Required]
        [Range(0, double.MaxValue)]
        public decimal CurrentWarranty { get; set; }

        public bool IsEnabled { get; set; }
    }
}
