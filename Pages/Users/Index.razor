@page "/users"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject ApplicationDbContext Context
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Users - Rent Tracker</PageTitle>

<h1>Users</h1>

<div class="mb-2">
    <a href="/users/add" class="btn btn-primary">Add User</a>
</div>

@if (_loading)
{
    <div class="d-flex align-center gap-1">
        <div class="spinner"></div>
        <span>Loading...</span>
    </div>
}
else if (!_users.Any())
{
    <div class="alert alert-info">No users found.</div>
}
else
{
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>Roles</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in _users)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.UserName</td>
                        <td>@GetUserRoles(user.Id)</td>
                        <td>
                            @if (user.RequiresPasswordChange)
                            {
                                <span class="badge badge-warning">Password Change Required</span>
                            }
                            else
                            {
                                <span class="badge badge-success">Active</span>
                            }
                        </td>
                        <td>
                            @if (user.UserName != "admin")
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => ResetPassword(user.Id)">Reset Password</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success mt-2">@_message</div>
}

@code {
    private bool _loading = true;
    private List<ApplicationUser> _users = [];
    private Dictionary<string, List<string>> _userRoles = [];
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        _loading = false;
    }

    private async Task LoadUsers()
    {
        _users = await UserManager.Users.OrderBy(u => u.FullName).ToListAsync();
        
        _userRoles = [];
        foreach (var user in _users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            _userRoles[user.Id] = roles.ToList();
        }
    }

    private string GetUserRoles(string userId)
    {
        return _userRoles.TryGetValue(userId, out var roles) ? string.Join(", ", roles) : "";
    }

    private async Task ResetPassword(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user == null || user.UserName == "admin") return;

        // Generate reset token and reset password
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, "password123");
        
        if (result.Succeeded)
        {
            user.RequiresPasswordChange = true;
            await UserManager.UpdateAsync(user);
            _message = $"Password reset for {user.FullName}. New password: password123";
        }
    }
}
