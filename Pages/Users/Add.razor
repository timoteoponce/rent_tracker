@page "/users/add"
@attribute [Authorize(Roles = "SystemAdministrator")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager Navigation

<PageTitle>Add User - Rent Tracker</PageTitle>

<h1>Add User</h1>

<EditForm Model="_user" OnValidSubmit="HandleSubmit" class="card">
    <DataAnnotationsValidator />
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="form-group">
        <label for="fullName">Full Name</label>
        <InputText id="fullName" @bind-Value="_user.FullName" class="form-control" required />
        <ValidationMessage For="() => _user.FullName" />
    </div>

    <div class="form-group">
        <label for="username">Username</label>
        <InputText id="username" @bind-Value="_user.UserName" class="form-control" required />
        <ValidationMessage For="() => _user.UserName" />
    </div>

    <div class="form-group">
        <label for="password">Password</label>
        <InputText type="password" id="password" @bind-Value="_user.Password" class="form-control" required />
        <ValidationMessage For="() => _user.Password" />
    </div>

    <div class="form-group">
        <label>Role</label>
        <InputSelect @bind-Value="_user.Role" class="form-control" required>
            <option value="">Select a role...</option>
            <option value="Owner">Owner</option>
            <option value="Tenant">Tenant</option>
        </InputSelect>
        <ValidationMessage For="() => _user.Role" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary" disabled="@_saving">
            @if (_saving)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Create User</span>
            }
        </button>
        <a href="/users" class="btn btn-outline">Cancel</a>
    </div>
</EditForm>

@code {
    private UserInput _user = new();
    private string? _errorMessage;
    private bool _saving;

    private async Task HandleSubmit()
    {
        if (_saving) return;
        _saving = true;
        _errorMessage = null;

        try
        {
            // Check if full name is unique
            var existingUser = await UserManager.FindByNameAsync(_user.UserName!);
            if (existingUser != null)
            {
                _errorMessage = "Username already exists.";
                return;
            }

            // Check if full name already exists
            var existingByFullName = (await UserManager.Users.ToListAsync()).Any(u => u.FullName == _user.FullName);
            if (existingByFullName)
            {
                _errorMessage = "A user with this full name already exists.";
                return;
            }

            var user = new ApplicationUser
            {
                UserName = _user.UserName,
                FullName = _user.FullName!,
                EmailConfirmed = true,
                RequiresPasswordChange = true
            };

            var result = await UserManager.CreateAsync(user, _user.Password!);
            if (!result.Succeeded)
            {
                _errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
                return;
            }

            // Add to role
            if (!string.IsNullOrEmpty(_user.Role))
            {
                await UserManager.AddToRoleAsync(user, _user.Role);
            }

            Navigation.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error creating user: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class UserInput
    {
        [Required]
        public string? FullName { get; set; }

        [Required]
        public string? UserName { get; set; }

        [Required]
        [StringLength(100, MinimumLength = 6)]
        public string? Password { get; set; }

        [Required]
        public string? Role { get; set; }
    }
}
