@page
@model RentTracker.Web.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Add User";
}

<div class="page-header">
    <h2>Add User</h2>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="page-content">
    <form method="post" class="form-horizontal">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="form-group">
            <label asp-for="User.Username"></label>
            <input asp-for="User.Username" class="form-control" placeholder="Leave blank to auto-generate" />
            <span asp-validation-for="User.Username" class="text-danger"></span>
            <small class="text-muted">Must be unique. Leave blank for auto-generated value.</small>
        </div>

        <div class="form-group">
            <label asp-for="User.Email"></label>
            <input asp-for="User.Email" class="form-control" placeholder="Leave blank to auto-generate" />
            <span asp-validation-for="User.Email" class="text-danger"></span>
            <small class="text-muted">Must be unique. Leave blank for auto-generated value.</small>
        </div>

        <div class="form-group">
            <label asp-for="User.FullName"></label>
            <input asp-for="User.FullName" class="form-control" placeholder="Display name (optional)" />
            <span asp-validation-for="User.FullName" class="text-danger"></span>
            <small class="text-muted">Optional display name for the user</small>
        </div>

        <div class="form-group">
            <label asp-for="User.Role"></label>
            <select asp-for="User.Role" class="form-control">
                <option value="">-- Select Role --</option>
                <option value="Administrator">Administrator</option>
                <option value="Owner">Owner</option>
                <option value="Tenant">Tenant</option>
            </select>
            <span asp-validation-for="User.Role" class="text-danger"></span>
            <small class="text-muted">Select the appropriate role for the user</small>
        </div>

        <div class="form-group">
            <label>Initial Password</label>
            <input type="text" value="password123" class="form-control" readonly />
            <small class="text-muted">User will be required to change this on first login</small>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Add User</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
