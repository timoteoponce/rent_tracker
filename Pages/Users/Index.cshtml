@page
@model RentTracker.Web.Pages.Users.IndexModel
@using RentTracker.Web.Models
@{
    ViewData["Title"] = "User Management";
}

<partial name="_PageHeader" model='new PageHeaderModel { Title = "User Management", ActionUrl = "./Create", ActionText = "Add User" }' />

<div class="page-content">
    @if (Model.Users.Any())
    {
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last Login</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.Username</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                <partial name="_StatusBadge" model='new StatusBadgeModel { Status = user.Role, Type = "UserRole" }' />
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Inactive</span>
                                }
                                @if (user.MustChangePassword)
                                {
                                    <span class="badge badge-warning ml-1">Password Change Required</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>@(user.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@user.Id" class="btn btn-sm btn-secondary">Edit</a>
                                @if (!user.IsSystemUser && user.Username != "admin")
                                {
                                    <form asp-page="./ToggleStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-danger" : "btn-success")">
                                            @(user.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                }
                                <form asp-page="./ResetPassword" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning" data-confirm="Reset password for @user.Username to 'password123'?">
                                        Reset
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model='new EmptyStateModel { Message = "No users found." }' />
    }
</div>
