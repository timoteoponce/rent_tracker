@page "{id:guid}"
@model RentTracker.Web.Pages.Leases.EditModel
@{
    ViewData["Title"] = "Edit Lease";
}

<div class="page-header">
    <h2>Edit Lease</h2>
    <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
</div>

<div class="page-content">
    <form method="post" class="form-horizontal">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="form-group">
            <label>Property</label>
            <p class="form-control-static">@Model.Lease.Property.Name</p>
        </div>

        <div class="form-group">
            <label>Tenant</label>
            <p class="form-control-static">@Model.Lease.Tenant.FullName</p>
        </div>

        @if (Model.Lease.Property.CanBeLeasedByUnits)
        {
            <div class="form-group">
                <label asp-for="Lease.PropertyUnitId"></label>
                <select asp-for="Lease.PropertyUnitId" asp-items="Model.AvailableUnits" class="form-control">
                    <option value="">-- Whole Property --</option>
                </select>
                <span asp-validation-for="Lease.PropertyUnitId" class="text-danger"></span>
                <small class="text-muted">Leave empty to lease the whole property</small>
            </div>
        }

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Lease.AgreedPrice"></label>
                <input asp-for="Lease.AgreedPrice" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Lease.AgreedPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Lease.AgreedWarranty"></label>
                <input asp-for="Lease.AgreedWarranty" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Lease.AgreedWarranty" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Lease.StartDate"></label>
                <input asp-for="Lease.StartDate" type="date" class="form-control" />
                <span asp-validation-for="Lease.StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Lease.EndDate"></label>
                <input asp-for="Lease.EndDate" type="date" class="form-control" />
                <span asp-validation-for="Lease.EndDate" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
