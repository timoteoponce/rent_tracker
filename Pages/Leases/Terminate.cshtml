@page "{id:guid}"
@model RentTracker.Web.Pages.Leases.TerminateModel
@{
    ViewData["Title"] = "Terminate Lease";
}

<div class="page-header">
    <h2>Terminate Lease</h2>
    <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
</div>

<div class="page-content">
    <div class="alert alert-warning">
        <h4>⚠️ Forcibly Terminate Lease</h4>
        <p>
            Property: <strong>@Model.Lease.Property.Name</strong><br>
            Tenant: <strong>@Model.Lease.Tenant.FullName</strong><br>
            Current Status: <strong>@Model.Lease.Status</strong>
        </p>
    </div>

    <p class="text-danger">
        <strong>Warning:</strong> This will forcibly terminate the lease before its natural end. 
        This should only be used when something unexpected happened (e.g., tenant eviction, breach of contract).
    </p>

    <form method="post" class="form-horizontal">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="form-group">
            <label asp-for="TerminationReason"></label>
            <textarea asp-for="TerminationReason" class="form-control" rows="3" placeholder="Enter the reason for termination (required)"></textarea>
            <span asp-validation-for="TerminationReason" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EndDate"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
            <small class="text-muted">Leave empty to use today's date</small>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-danger" data-confirm="Are you sure you want to forcibly terminate this lease? This action cannot be undone.">Terminate Lease</button>
            <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
