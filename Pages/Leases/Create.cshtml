@page
@model RentTracker.Web.Pages.Leases.CreateModel
@{
    ViewData["Title"] = "Create Lease";
}

<div class="page-header">
    <h2>Create Lease</h2>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="page-content">
    <form method="post" class="form-horizontal">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="form-group">
            <label asp-for="Lease.PropertyId"></label>
            <select asp-for="Lease.PropertyId" asp-items="Model.AvailableProperties" class="form-control" id="propertySelect">
                <option value="">-- Select Property --</option>
            </select>
            <span asp-validation-for="Lease.PropertyId" class="text-danger"></span>
        </div>

        <div class="form-group" id="unitSection" style="display: @(Model.ShowUnitSection ? "block" : "none");">
            <label asp-for="Lease.PropertyUnitId"></label>
            <select asp-for="Lease.PropertyUnitId" asp-items="Model.AvailableUnits" class="form-control" id="unitSelect">
                <option value="">-- Whole Property --</option>
            </select>
            <span asp-validation-for="Lease.PropertyUnitId" class="text-danger"></span>
            <small class="text-muted">Leave empty to lease the whole property</small>
        </div>

        <div class="form-group">
            <label asp-for="Lease.TenantId"></label>
            <select asp-for="Lease.TenantId" asp-items="Model.AvailableTenants" class="form-control">
                <option value="">-- Select Tenant --</option>
            </select>
            <span asp-validation-for="Lease.TenantId" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Lease.AgreedPrice"></label>
                <input asp-for="Lease.AgreedPrice" type="number" step="0.01" class="form-control" id="agreedPrice" />
                <span asp-validation-for="Lease.AgreedPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Lease.AgreedWarranty"></label>
                <input asp-for="Lease.AgreedWarranty" type="number" step="0.01" class="form-control" id="agreedWarranty" />
                <span asp-validation-for="Lease.AgreedWarranty" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Lease.StartDate"></label>
            <input asp-for="Lease.StartDate" type="date" class="form-control" />
            <span asp-validation-for="Lease.StartDate" class="text-danger"></span>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Create Lease</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            var propertySelect = document.getElementById('propertySelect');
            var unitSection = document.getElementById('unitSection');
            var unitSelect = document.getElementById('unitSelect');
            var agreedPriceInput = document.getElementById('agreedPrice');
            var agreedWarrantyInput = document.getElementById('agreedWarranty');

            function loadUnits(propertyId) {
                if (!propertyId) {
                    unitSection.style.display = 'none';
                    agreedPriceInput.value = '';
                    agreedWarrantyInput.value = '';
                    return;
                }

                fetch('?handler=Units&propertyId=' + propertyId)
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.canBeLeasedByUnits) {
                            unitSection.style.display = 'block';
                            unitSelect.innerHTML = '<option value="">-- Whole Property --</option>';
                            data.units.forEach(function(unit) {
                                var option = document.createElement('option');
                                option.value = unit.id;
                                option.textContent = unit.name + ' (Bs. ' + unit.price.toFixed(2) + ')';
                                if (!unit.isAvailable) {
                                    option.disabled = true;
                                    option.textContent += ' (Occupied)';
                                }
                                unitSelect.appendChild(option);
                            });
                        } else {
                            unitSection.style.display = 'none';
                            unitSelect.value = '';
                        }

                        agreedPriceInput.value = data.defaultPrice.toFixed(2);
                        agreedWarrantyInput.value = data.defaultWarranty.toFixed(2);
                    })
                    .catch(function() {
                        // fallback: keep server-rendered options
                    });
            }

            propertySelect.addEventListener('change', function() {
                loadUnits(this.value);
            });

            unitSelect.addEventListener('change', function() {
                var unitId = this.value;
                if (unitId) {
                    var selectedOption = this.options[this.selectedIndex];
                    var priceMatch = selectedOption.textContent.match(/Bs\.\s+([\d,.]+)/);
                    if (priceMatch) {
                        agreedPriceInput.value = parseFloat(priceMatch[1].replace(',', '')).toFixed(2);
                    }
                }
            });
        })();
    </script>
}
