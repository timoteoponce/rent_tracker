@page "{id:guid}"
@model RentTracker.Web.Pages.Leases.CloseModel
@{
    ViewData["Title"] = "Close Lease";
}

<div class="page-header">
    <h2>Close Lease</h2>
    <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
</div>

<div class="page-content">
    <div class="alert alert-info">
        <h4>Close Lease for @Model.Lease.Property.Name</h4>
        <p>
            Tenant: <strong>@Model.Lease.Tenant.FullName</strong><br>
            Current Monthly Rent: <strong>Bs. @Model.Lease.AgreedPrice.ToString("N2")</strong><br>
            Start Date: <strong>@Model.Lease.StartDate.ToString("dd MMM yyyy")</strong>
        </p>
    </div>

    <p>This will mark the lease as normally completed. The property/unit will become available for new leases.</p>

    <form method="post" class="form-horizontal">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="form-group">
            <label asp-for="EndDate"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
            <small class="text-muted">Leave empty to use today's date</small>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-secondary" data-confirm="Are you sure you want to close this lease?">Close Lease</button>
            <a asp-page="./Details" asp-route-id="@Model.Lease.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
